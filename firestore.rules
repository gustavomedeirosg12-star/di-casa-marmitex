rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - customerName: string (required, < 100 chars)
    //   - orderType: string (required, 'delivery' | 'pickup')
    //   - address: string (optional, < 500 chars)
    //   - paymentMethod: string (required, 'pix' | 'credit' | 'debit' | 'cash')
    //   - items: list (required, < 50 items)
    //   - total: number (required, >= 0)
    //   - status: string (required, 'Novos' | 'Preparando' | 'Saiu para Entrega' | 'Finalizados')
    //   - createdAt: timestamp (required)
    //
    // Collection: products
    // Document ID: auto-generated or custom
    // Fields:
    //   - name: string (required, < 100 chars)
    //   - description: string (required, < 500 chars)
    //   - price: number (required, >= 0)
    //   - category: string (required, 'Pratos Feitos' | 'Marmitex' | 'Espetinhos' | 'Jantinhas')
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidOrder(data) {
      let allowedFields = ['customerName', 'orderType', 'address', 'paymentMethod', 'items', 'total', 'status', 'createdAt'];
      
      return hasRequiredFields(['customerName', 'orderType', 'paymentMethod', 'items', 'total', 'status', 'createdAt']) &&
             hasOnlyAllowedFields(allowedFields) &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.orderType in ['delivery', 'pickup'] &&
             (!('address' in data) || (data.address is string && data.address.size() < 500)) &&
             data.paymentMethod in ['pix', 'credit', 'debit', 'cash'] &&
             data.items is list && data.items.size() > 0 && data.items.size() < 50 &&
             data.total is number && data.total >= 0 &&
             data.status in ['Novos', 'Preparando', 'Saiu para Entrega', 'Finalizados'] &&
             data.createdAt is timestamp;
    }

    function isValidProduct(data) {
      let allowedFields = ['name', 'description', 'price', 'category'];
      
      return hasRequiredFields(allowedFields) &&
             hasOnlyAllowedFields(allowedFields) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.description is string && data.description.size() >= 0 && data.description.size() < 500 &&
             data.price is number && data.price >= 0 &&
             data.category in ['Pratos Feitos', 'Marmitex', 'Espetinhos', 'Jantinhas'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /orders/{orderId} {
      // Allow unauthenticated creates for new orders from the menu
      allow create: if isValidOrder(request.resource.data) && request.resource.data.status == 'Novos';
      
      // Only authenticated users (admins/staff) can read or update orders
      // In a real app, you might want to restrict this to specific admin UIDs or roles.
      allow read, update, delete: if isAuthenticated();
    }

    match /products/{productId} {
      // Anyone can read the menu
      allow read: if true;

      // Only authenticated users can modify the menu
      allow create: if isAuthenticated() && isValidProduct(request.resource.data);
      allow update: if isAuthenticated() && isValidProduct(request.resource.data);
      allow delete: if isAuthenticated();
    }
  }
}
